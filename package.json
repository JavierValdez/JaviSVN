{
  "name": "javisvn",
  "version": "1.4.0",
  "description": "SVN Desktop Client - Cliente SVN estilo GitHub Desktop",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "bash scripts/bundle-svn.sh && electron-vite build",
    "start": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^8.2.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.javisvn.app",
    "productName": "JaviSVN",
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 360,
          "type": "file",
          "path": "resources/LEER_ANTES_DE_ABRIR.txt"
        }
      ]
    },
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/lib",
        "to": "lib",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/LEER_ANTES_DE_ABRIR.txt",
        "to": "LEER_ANTES_DE_ABRIR.txt"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
